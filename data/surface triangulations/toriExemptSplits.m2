        {7, {2, 4}}, {7, {2, 3}}, {7, {2, 5}}, {7, {0, 3}}, {7, {0, 5}}, {7, {0, 6}}, {7, {4, 5}}, {7, {4, 6}}, {7, {3, 6}}},

    -- irredTori_2: 8-vertex torus.
    -- The automorphism group is of order 4, with non-trivial elements (vertex permutations):
    --   (1 3)(2 6)
    --   (0 5)(1 3)(4 7)
    --   (0 5)(2 6)(4 7)
    -- Vertex orbits: {0,5}, {1,3}, {2,6}, {4,7}.
    -- Representatives chosen: bases 0, 1, 2, 4 (one per orbit).
    -- Reps at base 0: {1,2}, {1,4}, {2,6}
    -- Reps at base 1: {0,2},{0,4},{0,5},{0,7},{2,3},{2,6},{2,7},{3,4}
    -- Reps at base 2: {0,1},{0,5},{0,7},{1,3},{1,7},{4,7}
