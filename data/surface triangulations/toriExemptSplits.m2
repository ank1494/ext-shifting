        {3, {1, 2}}, {3, {1, 5}}, {3, {1, 7}}, {3, {0, 5}}, {3, {0, 7}}, {3, {0, 4}}, {3, {2, 7}}, {3, {2, 4}}, {3, {4, 5}},
        {4, {6, 7}}, {4, {3, 6}}, {4, {1, 6}}, {4, {0, 3}}, {4, {0, 1}}, {4, {0, 5}}, {4, {1, 7}}, {4, {5, 7}}, {4, {3, 5}},
