        {4, {6, 7}}, {4, {2, 3}}, {4, {0, 3}},
        {5, {1, 6}}, {5, {1, 7}}, {5, {3, 7}}, {5, {2, 3}}, {5, {2, 6}},
        {6, {4, 5}}, {6, {0, 5}}, {6, {1, 5}}, {6, {0, 3}}, {6, {1, 3}}, {6, {3, 7}}, {6, {1, 4}}, {6, {4, 7}}, {6, {0, 7}},
        {7, {2, 6}}, {7, {1, 2}}, {7, {2, 4}}, {7, {1, 5}}, {7, {4, 5}}, {7, {3, 5}}, {7, {4, 6}}, {7, {3, 6}}, {7, {1, 3}}},

    -- irredTori_3: 8-vertex torus.
    -- The automorphism group is of order 6 with non-trivial elements:
    --   (0 5)(1 4)(3 6)
    --   (2 4)(3 6)(5 7)
    --   (0 7)(1 2)(3 6)
    --   (0 7 5)(1 2 4)
    --   (0 5 7)(1 4 2)
    -- Vertex orbits: {0,5,7}, {1,2,4}, {3,6}.
    -- Representatives chosen: bases 0, 1, 3 (one per orbit).
    -- Reps at base 0: {1,2}, {2,6}, {3,6}
    -- Reps at base 1: {0,2},{0,5},{2,3},{2,6},{2,7},{3,6},{3,7},{5,7}
    -- Reps at base 3: {0,4},{0,5},{1,2}
    irredTori_3 => {
        {0, {1, 4}}, {0, {3, 4}},
        {1, {0, 4}}, {1, {0, 7}}, {1, {3, 4}}, {1, {4, 5}}, {1, {5, 6}}, {1, {4, 6}},
