        {3, {0, 7}}, {3, {1, 4}}, {3, {1, 7}}, {3, {5, 7}}, {3, {2, 5}}, {3, {2, 4}},
        {4, {3, 6}}, {4, {0, 3}}, {4, {2, 3}}, {4, {1, 3}}, {4, {0, 5}}, {4, {2, 5}}, {4, {1, 5}}, {4, {5, 7}}, {4, {2, 6}}, {4, {1, 6}}, {4, {6, 7}}, {4, {0, 1}}, {4, {0, 7}}, {4, {2, 7}},
        {5, {1, 4}}, {5, {1, 6}}, {5, {3, 6}}, {5, {2, 3}}, {5, {2, 4}},
        {6, {2, 4}}, {6, {4, 7}}, {6, {1, 4}}, {6, {5, 7}}, {6, {1, 5}}, {6, {0, 5}}, {6, {1, 2}}, {6, {0, 2}}, {6, {0, 7}},
        {7, {3, 6}}, {7, {4, 6}}, {7, {2, 4}}, {7, {1, 2}}, {7, {1, 3}}},

    -- irredTori_4: 8-vertex torus.
    -- The automorphism group is of order 4, with non-trivial elements:
    --   (1 3)(2 4)
    --   (1 2)(3 4)(5 7)
    --   (1 4)(2 3)(5 7)
    -- Vertex orbits: {1,2,3,4}, {5,7}, {0} (fixed), {6} (fixed).
    -- Vertex 0 has degree 4; its splits are expected critical regions and are not exempted here.
    -- Representatives chosen: bases 0 (all — fixed point), 1 (all — trivial stabiliser),
    --   5 (reps {1,4},{1,6},{2,4}), 6 (reps {1,2},{1,3},{1,5},{5,7}).
    irredTori_4 => {
        {2, {1, 6}}, {2, {1, 3}}, {2, {0, 1}}, {2, {1, 4}}, {2, {3, 5}}, {2, {0, 5}}, {2, {4, 5}}, {2, {5, 7}}, {2, {0, 6}}, {2, {4, 6}}, {2, {6, 7}}, {2, {3, 4}}, {2, {3, 7}}, {2, {0, 7}},
        {3, {0, 5}}, {3, {0, 4}}, {3, {0, 7}}, {3, {0, 6}}, {3, {1, 4}}, {3, {1, 7}}, {3, {1, 6}}, {3, {1, 2}}, {3, {5, 7}}, {3, {5, 6}}, {3, {2, 5}}, {3, {4, 6}}, {3, {2, 4}}, {3, {2, 7}},
