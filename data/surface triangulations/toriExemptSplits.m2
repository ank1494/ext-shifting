        {5, {0, 2}}, {5, {0, 3}}, {5, {0, 6}}, {5, {1, 2}}, {5, {1, 3}}, {5, {1, 4}}, {5, {2, 6}}, {5, {3, 4}}, {5, {4, 6}},
        {6, {0, 1}}, {6, {0, 3}}, {6, {0, 5}}, {6, {1, 3}}, {6, {1, 4}}, {6, {2, 3}}, {6, {2, 4}}, {6, {2, 5}}, {6, {4, 5}}},

    -- irredTori_1: 8-vertex torus.
    -- The automorphism group is transitive on vertices, so we only split at vertex 0.
    -- The orbits of non-trivial splits at vertex 0 (pairs of link neighbours) are:
    --   {1,7}
    --   {2,6}, {3,4}
    --   {1,2}, {1,4}, {3,7}, {6,7}
    --   {2,4}, {3,6}
    -- Taking one representative per orbit leaves 4 non-exempt splits at vertex 0.
    irredTori_1 => {
        {0, {3, 6}}, {0, {3, 4}}, {0, {3, 7}}, {0, {1, 4}}, {0, {6, 7}},
        {1, {3, 6}}, {1, {2, 3}}, {1, {3, 5}}, {1, {0, 2}}, {1, {0, 5}}, {1, {0, 4}}, {1, {5, 6}}, {1, {4, 6}}, {1, {2, 4}},
