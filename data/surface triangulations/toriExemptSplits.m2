-- Exempt vertex splits for the iterative torus analysis, organised by triangulation.
-- Exemptions are automorphism-based: only representative vertex splits are retained;
-- symmetry-equivalent splits are omitted to avoid redundant computation.

irredTori := value get "data/surface triangulations/irredTori.m2";
new HashTable from {

    -- irredTori_0: 7-vertex minimal torus.
    -- The automorphism group is transitive on vertices (order 42, the maximum for a 7-vertex
    -- surface), so we only need to split at one vertex.  The stabiliser of a vertex acts on
    -- its star by rotations, giving two orbits of non-trivial splits: ratio (3,3) and ratio
    -- (2,4).  We take one representative of each, leaving 2 non-exempt splits at vertex 0.
    irredTori_0 => {
        {0, {1, 4}}, {0, {2, 4}}, {0, {2, 5}}, {0, {3, 4}}, {0, {3, 5}}, {0, {3, 6}}, {0, {5, 6}},
        {1, {0, 2}}, {1, {0, 4}}, {1, {0, 6}}, {1, {2, 3}}, {1, {2, 5}}, {1, {3, 5}}, {1, {3, 6}}, {1, {4, 5}}, {1, {4, 6}},
